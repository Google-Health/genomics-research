+# SERVICES; LOSS OF USE, DATA, OR PROFITS; OR BUSINESS INTERRUPTION) HOWEVER
+# CAUSED AND ON ANY THEORY OF LIABILITY, WHETHER IN CONTRACT, STRICT LIABILITY,
+# OR TORT (INCLUDING NEGLIGENCE OR OTHERWISE) ARISING IN ANY WAY OUT OF THE USE
+# OF THIS SOFTWARE, EVEN IF ADVISED OF THE POSSIBILITY OF SUCH DAMAGE.
+r"""Script for generating predictions from a single model.
+
+Model predictions are written to a CSV with a unique `predict_utils.ID_KEY` ID
+column corresponding to each input image. The CSV contains a column for each
+classification and regression target, i.e., a multiclass outcome of shape
+`(None, N)` will have `N` columns. See `predict_utils.OUTCOME_COLUMN_MAP` for
+column mapping.
+
+This script should be run with the same `checkpoint_dir` and `config` used in
+training.
+
+Note: If generating predictions with a single member of an ensemble trained
+using the `train_ensemble.py` script, the provided checkpoint_dir should
+correspond to the member's subdirectory, e.g.,
+`base_workdir/member_{i}/{checkpoint_dir}`.
+
+Example usages:
+
+# Generating predictions with a single model trained using `train.py`:
+$ python3 predict.py \
+    --config=configs/base.py \
+    --checkpoint_dir=./vcdr/checkpoints/val_loss \
+    --output_filepath=./outcome_predictions.csv
+
+# Generating predictions with an ensemble member trained using
+# `train_ensemble.py`:
+$ python3 predict.py \
+    --config=configs/base.py \
+    --checkpoint_dir=./vcdr_ensemble_base/member_9/checkpoints/val_loss \
+    --output_filepath=./outcome_predictions.csv
+"""
+import pathlib
+
+from absl import app
+from absl import flags
+import ml_collections
+from ml_collections import config_flags
+import model_utils
+import tensorflow as tf
+
+FLAGS = flags.FLAGS
+
+config_flags.DEFINE_config_file(
+    'config',
+    None,
+    'A resource path to the ConfigDict used during training.',
+    lock_config=True,
+)
+flags.DEFINE_string('checkpoint_dir', None, 'The checkpoint directory')
+flags.DEFINE_string(
+    'output_filepath',
+    'predictions.csv',
+    'The filepath at which the output CSV is written.',
+)
+
+
+def save(
+    checkpoint_dir: pathlib.Path,
+    config: ml_collections.ConfigDict,
+    output_filepath: str,
+) -> None:
+  """Generates model predictions using the best available checkpoint."""
+  # Load the best checkpoint
+  _, model = model_utils.get_model(config)
+  best_checkpoint = tf.train.latest_checkpoint(checkpoint_dir)
+  print(f'Loading model from {best_checkpoint}...')
+  model.load_weights(best_checkpoint).expect_partial()
+  #  model.save(checkpoint_dir / 'model.h6', include_optimizer=False)
+  model.save(checkpoint_dir / 'saved_model.keras', include_optimizer=False)
+
+
+def main(unused_argv):
+  print('Saving full model:')
+  print(FLAGS.config)
+  save(
+      checkpoint_dir=pathlib.Path(FLAGS.checkpoint_dir),
+      config=FLAGS.config,
+      output_filepath=FLAGS.output_filepath,
+  )
+
+
+if __name__ == '__main__':
+  flags.mark_flags_as_required(['config', 'checkpoint_dir'])
+  app.run(main)
