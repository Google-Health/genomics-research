+"""Utilities for defining tensorflow keras callbacks."""
+import pathlib
+from typing import Dict, List
+
+import ml_collections
+import tensorflow as tf
+import tensorflow_addons as tfa
+
+# The prefix prepended to validation metrics and losses by tensorflow keras.
+_VAL_PREFIX = 'val'
+
+# The suffix appended to validation losses by tensorflow keras.
+_LOSS_SUFFIX = 'loss'
+
+# The base validation loss created by tensorflow keras.
+_VAL_LOSS = f'{_VAL_PREFIX}_{_LOSS_SUFFIX}'
+
+
+def get_checkpoint_dirs(
+    base_checkpoint_dir: pathlib.Path,
+    config: ml_collections.ConfigDict,
+) -> Dict[str, pathlib.Path]:
+  """Returns a mapping of metric to checkpoint directories for the given config.
+
+  If a single metric is specified using `config.callbacks.checkpoint_monitor`,
+  we monitor and checkpoint for only that metric. If `checkpoint_monitor` is not
+  specified, we monitor and checkpoint for each individual outcome as well as
+  the global `val_loss`.
+
+  Args:
+    base_checkpoint_dir: The base checkpoint directory.
+    config: The experimental configuration.
+
+  Returns:
+    A mapping of validation outcome names to checkpoint directories.
+  """
+  callbacks_config = config.get('callbacks', {})
+  checkpoint_monitor = callbacks_config.get('checkpoint_monitor', None)
+  if checkpoint_monitor is not None:
+    return {checkpoint_monitor: base_checkpoint_dir / checkpoint_monitor}
+
+  checkpoint_dirs = {_VAL_LOSS: base_checkpoint_dir / _VAL_LOSS}
+  for outcome in config.outcomes:
+    val_outcome_name = f'{_VAL_PREFIX}_{outcome.name}_{_LOSS_SUFFIX}'
+    if val_outcome_name in checkpoint_dirs:
+      raise ValueError(
+          f'Cannot checkpoint duplicate outcome name: {val_outcome_name!r}')
+    checkpoint_dirs[val_outcome_name] = base_checkpoint_dir / val_outcome_name
+
+  return checkpoint_dirs
+
+
+def _get_checkpoint_callbacks_for_metric(
+    checkpoint_monitor: str,
+    checkpoint_dir: pathlib.Path,
+    use_model_averaging: bool,
+    update_model_averaging_weights: bool,
+) -> List[tf.keras.callbacks.Callback]:
+  """Returns the list of checkpoint callbacks for a given metric.
+
+  Args:
+    checkpoint_monitor: The value monitored by the checkpoint callback.
+    checkpoint_dir: The directory in which checkpoints are written.
+    use_model_averaging: Whether checkpoints use model averaging; see
+      tfa.callbacks.AverageModelCheckpoint for details.
+    update_model_averaging_weights: Whether model weights are updated with the
+      running model average. If `False` when using model averaging, a second
+      checkpoint callback is included to save unaveraged model weights.
+
+  Returns:
+    A list of checkpoint callbacks for the given `checkpoint_monitor` metric.
+  """
+  checkpoint_file = checkpoint_dir / 'weights.best.ckpt'
+  checkpoint_file_avg = checkpoint_dir / 'weights.avg.best.ckpt'
+
+  checkpoint_callbacks = []
+  if use_model_averaging:
+    checkpoint_callbacks.append(
+        tfa.callbacks.AverageModelCheckpoint(
+            filepath=str(checkpoint_file_avg),
+            update_weights=update_model_averaging_weights,
+            save_best_only=True,
+            save_weights_only=True,
+            monitor=checkpoint_monitor,
+            mode='auto',
+            save_freq='epoch'))
+
+    # If not updating model weights to include variable averages, checkpoint
+    # both the standard and averaged model.
+    if not update_model_averaging_weights:
+      checkpoint_callbacks.append(
+          tf.keras.callbacks.ModelCheckpoint(
+              filepath=checkpoint_file,
+              save_best_only=True,
+              save_weights_only=True,
+              monitor=checkpoint_monitor,
+              mode='auto',
+              save_freq='epoch'))
+
+  else:
+    checkpoint_callbacks.append(
+        tf.keras.callbacks.ModelCheckpoint(
+            filepath=checkpoint_file,
+            save_best_only=True,
+            save_weights_only=True,
+            monitor=checkpoint_monitor,
+            mode='auto',
+            save_freq='epoch'))
+
+  return checkpoint_callbacks
+
+
+def _get_checkpoint_callbacks(
+    workdir: pathlib.Path,
+    config: ml_collections.ConfigDict,
+) -> List[tf.keras.callbacks.Callback]:
+  """Builds and returns a list of tensorflow callbacks for checkpointing.
+
+  If a single metric is specified using `config.callbacks.checkpoint_monitor`,
+  we monitor and checkpoint for only that metric. If `checkpoint_monitor` is not
+  specified, we monitor and checkpoint for each individual outcome as well as
+  the global `val_loss`.
+
+  Args:
+    workdir: The directory where logs and checkpoints are saved.
+    config: The experimental configuration.
+
+  Returns:
+    A list of tensorflow callbacks for checkpointing.
+  """
+  base_checkpoint_dir = workdir / 'checkpoints'
+  use_model_averaging = config.opt.use_model_averaging
+  updated_weights = config.opt.get('update_model_averaging_weights', True)
+
+  checkpoint_callbacks = []
+  checkpoint_dirs = get_checkpoint_dirs(base_checkpoint_dir, config)
+  for checkpoint_monitor, checkpoint_dir in checkpoint_dirs.items():
+    checkpoint_callbacks.extend(
+        _get_checkpoint_callbacks_for_metric(
+            checkpoint_monitor,
+            checkpoint_dir,
+            use_model_averaging,
+            updated_weights,
+        ))
+  return checkpoint_callbacks
+
+
+def get_callbacks(
+    workdir: pathlib.Path,
+    config: ml_collections.ConfigDict,
+) -> List[tf.keras.callbacks.Callback]:
+  """Builds and returns a list of tensorflow callbacks for use in training.
+
+  Args:
+    workdir: The directory where logs and checkpoints are saved.
+    config: The experimental configuration.
+
+  Returns:
+    A list of tensorflow callbacks for TensorBoard and checkpointing.
+  """
+  callbacks = [
+      tf.keras.callbacks.TensorBoard(log_dir=workdir / 'logs'),
+      *_get_checkpoint_callbacks(workdir, config),
+  ]
+  return callbacks
